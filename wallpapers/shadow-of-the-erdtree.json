{
  "name": "Shadow of the Erd Tree",
  "colors": {
    "bg0": "#0B0B0F",
    "bg1": "#1A1610",
    "bg2": "#2B2420",
    "bg3": "#3D3530",
    "border": "#C8A84E",
    "accent1": "#D4AF37",
    "accent2": "#B5722A",
    "text": "#E8D5B5",
    "text_dim": "#A89070",
    "red": "#8B2500",
    "green": "#5A7247",
    "blue": "#4A6A7A",
    "inactive": "#4A4035"

  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-dark",
    "theme": "Adwaita-dark"
  },
  "waybar": {
    "height": 34,
    "separator": "◆",
    "opacity": 0.82,
    "border_width": 2,
    "workspace_labels": [

{
  "name": "Scarlet Rot",
  "colors": {
    "bg0": "#F8F2EB",
    "bg1": "#F0E6DA",
    "bg2": "#E5D8C8",
    "bg3": "#D8C8B5",
    "border": "#cc6633",
    "accent1": "#cc3333",
    "accent2": "#996633",
    "text": "#2A1A0A",
    "text_dim": "#663300",
    "red": "#B83030",
    "green": "#4A7A3A",
    "blue": "#3878A0",

  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-light",
    "theme": "Adwaita"
  },
  "waybar": {
    "height": 34,
    "separator": "◆",
    "opacity": 0.85,

{
  "name": "Aeonia",
  "colors": {
    "bg0": "#0F0808",
    "bg1": "#1C1210",
    "bg2": "#2D1F1A",
    "bg3": "#3E2C25",
    "border": "#E8512E",
    "accent1": "#FF6B3D",
    "accent2": "#FFA040",
    "text": "#F4DCCC",
    "text_dim": "#C4A088",
    "red": "#E83838",
    "green": "#A8B860",
    "blue": "#5C9BBE",
    "inactive": "#5A453E",
    "saturation": 0.30
  },
  "hyprland": {
    "border_size": 2,
    "rounding": 4,
    "gaps_in": 4,
    "gaps_out": 16,
    "shadow_range": 8,
    "shadow_render_power": 3,
    "blur_size": 5,
    "blur_passes": 2,
    "blur_vibrancy": 0.2,
    "active_opacity": 1.0,
    "inactive_opacity": 0.93,
    "animation_speed_global": 12,
    "animation_speed_border": 6,
    "animation_speed_windows": 5.5,
    "animation_speed_windows_in": 5,
    "animation_speed_windows_out": 2,
    "animation_speed_fade_in": 2.5,
    "animation_speed_fade_out": 2,
    "animation_speed_workspaces": 3
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-dark",
    "theme": "Adwaita-dark"
  },
  "waybar": {
    "height": 34,
    "separator": "❋",
    "opacity": 0.82,
    "border_width": 2,
    "workspace_labels": [
      "I",
      "II",
      "III",
      "IV",
      "V",
      "VI",
      "VII",
      "VIII",
      "IX",
      "X"
    ]
  },
  "wallpapers": {
    "fit_mode": "cover",
    "images": [
      "elden-ring/aeonia-*.*"
    ],
    "videos": [],
    "cycle_interval": 300
  }
}

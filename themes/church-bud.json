{
  "name": "Church of the Bud",
  "colors": {
    "bg0": "#F5EBE8",
    "bg1": "#ECDDD8",
    "bg2": "#E0CEC8",
    "bg3": "#D4BEB5",
    "border": "#C87888",
    "accent1": "#D88898",
    "accent2": "#A85848",
    "text": "#2A1818",
    "text_dim": "#785058",
    "red": "#B84040",
    "green": "#6A8858",
    "blue": "#7888A0",
    "inactive": "#B0A098"
  },
  "hyprland": {
    "border_size": 2,
    "rounding": 4,
    "gaps_in": 4,
    "gaps_out": 16,
    "shadow_range": 8,
    "shadow_render_power": 3,
    "blur_size": 5,
    "blur_passes": 2,
    "blur_vibrancy": 0.2,
    "active_opacity": 1.0,
    "inactive_opacity": 0.93,
    "animation_speed_global": 12,
    "animation_speed_border": 6,
    "animation_speed_windows": 5.5,
    "animation_speed_windows_in": 5,
    "animation_speed_windows_out": 2,
    "animation_speed_fade_in": 2.5,
    "animation_speed_fade_out": 2,
    "animation_speed_workspaces": 3
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-light",
    "theme": "Adwaita"
  },
  "waybar": {
    "height": 34,
    "separator": "\ue28e",
    "opacity": 0.85,
    "border_width": 2,
    "workspace_labels": [
      "I",
      "II",
      "III",
      "IV",
      "V",
      "VI",
      "VII",
      "VIII",
      "IX",
      "X"
    ]
  },
  "wallpapers": {
    "fit_mode": "cover",
    "images": [
      "elden-ring/churchbud-*.*"
    ],
    "videos": [],
    "cycle_interval": 300
  }
}

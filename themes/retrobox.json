{
  "name": "Retrobox",
  "colors": {
    "bg0": "#1c1c1c",
    "bg1": "#262626",
    "bg2": "#303030",
    "bg3": "#3c3836",
    "border": "#fabd2f",
    "accent1": "#b8bb26",
    "accent2": "#fe8019",
    "text": "#ebdbb2",
    "text_dim": "#a89984",
    "red": "#fb5944",
    "green": "#b8bb26",
    "blue": "#83a598",
    "inactive": "#504945",
    "saturation": 0.15
  },
  "hyprland": {
    "border_size": 2,
    "rounding": 4,
    "gaps_in": 4,
    "gaps_out": 16,
    "shadow_range": 8,
    "shadow_render_power": 3,
    "blur_size": 5,
    "blur_passes": 2,
    "blur_vibrancy": 0.2,
    "active_opacity": 1.0,
    "inactive_opacity": 0.93,
    "animation_speed_global": 12,
    "animation_speed_border": 6,
    "animation_speed_windows": 5.5,
    "animation_speed_windows_in": 5,
    "animation_speed_windows_out": 2,
    "animation_speed_fade_in": 2.5,
    "animation_speed_fade_out": 2,
    "animation_speed_workspaces": 3
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-dark",
    "theme": "Adwaita-dark"
  },
  "waybar": {
    "height": 34,
    "separator": "\u2630",
    "opacity": 0.82,
    "border_width": 2,
    "workspace_labels": [
      "I",
      "II",
      "III",
      "IV",
      "V",
      "VI",
      "VII",
      "VIII",
      "IX",
      "X"
    ]
  },
  "wallpapers": {
    "fit_mode": "cover",
    "images": [],
    "videos": [],
    "lotties": [
      "retrobox/lines.lottie"
    ],
    "cycle_interval": 300
  },
  "nvim": {
    "colorscheme": "retrobox"
  }
}

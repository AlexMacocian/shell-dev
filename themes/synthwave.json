{
  "name": "Synthwave",
  "colors": {
    "bg0": "#1a0b2e",
    "bg1": "#241040",
    "bg2": "#2e1654",
    "bg3": "#0f0720",
    "border": "#ff2a93",
    "accent1": "#cc18eb",
    "accent2": "#ffcc66",
    "text": "#ffd1f5",
    "text_dim": "#b06bd6",
    "red": "#ff2a93",
    "green": "#36e0d4",
    "blue": "#6619b3",
    "inactive": "#241040",
    "saturation": 0.15
  },
  "hyprland": {
    "border_size": 2,
    "rounding": 4,
    "gaps_in": 4,
    "gaps_out": 16,
    "shadow_range": 8,
    "shadow_render_power": 3,
    "blur_size": 5,
    "blur_passes": 2,
    "blur_vibrancy": 0.2,
    "active_opacity": 1.0,
    "inactive_opacity": 0.93,
    "animation_speed_global": 12,
    "animation_speed_border": 6,
    "animation_speed_windows": 5.5,
    "animation_speed_windows_in": 5,
    "animation_speed_windows_out": 2,
    "animation_speed_fade_in": 2.5,
    "animation_speed_fade_out": 2,
    "animation_speed_workspaces": 3
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-dark",
    "theme": "Adwaita-dark"
  },
  "waybar": {
    "height": 34,
    "separator": "\u039B",
    "opacity": 0.82,
    "border_width": 2,
    "workspace_labels": [
      "I",
      "II",
      "III",
      "IV",
      "V",
      "VI",
      "VII",
      "VIII",
      "IX",
      "X"
    ]
  },
  "wallpapers": {
    "fit_mode": "cover",
    "images": [],
    "videos": [],
    "shaders": [
      {
        "path": "synthwave/sunset.frag",
        "duration_seconds": 20,
        "fps": 30,
        "width": 1920,
        "height": 1080
      }
    ],
    "cycle_interval": 300
  }
}

{
  "name": "Saint Trina",
  "colors": {
    "bg0": "#0E0C14",
    "bg1": "#181522",
    "bg2": "#242030",
    "bg3": "#302B40",
    "border": "#A55FE8",
    "accent1": "#9447D8",
    "accent2": "#6B5FE0",
    "text": "#D8D0EC",
    "text_dim": "#9C90B8",
    "red": "#E04860",
    "green": "#80B870",
    "blue": "#6488DC",
    "inactive": "#4E4468",
    "saturation": 0.20
  },
  "hyprland": {
    "border_size": 2,
    "rounding": 4,
    "gaps_in": 4,
    "gaps_out": 16,
    "shadow_range": 8,
    "shadow_render_power": 3,
    "blur_size": 5,
    "blur_passes": 2,
    "blur_vibrancy": 0.2,
    "active_opacity": 1.0,
    "inactive_opacity": 0.93,
    "animation_speed_global": 12,
    "animation_speed_border": 6,
    "animation_speed_windows": 5.5,
    "animation_speed_windows_in": 5,
    "animation_speed_windows_out": 2,
    "animation_speed_fade_in": 2.5,
    "animation_speed_fade_out": 2,
    "animation_speed_workspaces": 3
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-dark",
    "theme": "Adwaita-dark"
  },
  "waybar": {
    "height": 34,
    "separator": "🙞",
    "opacity": 0.82,
    "border_width": 2,
    "workspace_labels": [
      "I",
      "II",
      "III",
      "IV",
      "V",
      "VI",
      "VII",
      "VIII",
      "IX",
      "X"
    ]
  },
  "wallpapers": {
    "fit_mode": "cover",
    "images": [
      "elden-ring/sttrina-*.*"
    ],
    "videos": [],
    "cycle_interval": 300
  }
}

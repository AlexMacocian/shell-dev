{
  "name": "Cantha",
  "colors": {
    "bg0": "#F5EFF5",
    "bg1": "#EBE3ED",
    "bg2": "#DED5E2",
    "bg3": "#D0C5D5",
    "border": "#B8267A",
    "accent1": "#A82888",
    "accent2": "#1F8050",
    "text": "#0F0A1A",
    "text_dim": "#3D3450",
    "red": "#B01515",
    "green": "#1F7A45",
    "blue": "#1F6F88",
    "inactive": "#7A7088",
    "saturation": 0.20
  },
  "hyprland": {
    "border_size": 2,
    "rounding": 6,
    "gaps_in": 4,
    "gaps_out": 16,
    "shadow_range": 10,
    "shadow_render_power": 3,
    "blur_size": 6,
    "blur_passes": 2,
    "blur_vibrancy": 0.25,
    "active_opacity": 1.0,
    "inactive_opacity": 0.95,
    "animation_speed_global": 10,
    "animation_speed_border": 5,
    "animation_speed_windows": 5,
    "animation_speed_windows_in": 4.5,
    "animation_speed_windows_out": 2,
    "animation_speed_fade_in": 2.5,
    "animation_speed_fade_out": 2,
    "animation_speed_workspaces": 3
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-light",
    "theme": "Adwaita"
  },
  "waybar": {
    "height": 34,
    "separator": "✿",
    "opacity": 0.88,
    "border_width": 2,
    "workspace_labels": [
      "I",
      "II",
      "III",
      "IV",
      "V",
      "VI",
      "VII",
      "VIII",
      "IX",
      "X"
    ]
  },
  "wallpapers": {
    "fit_mode": "cover",
    "images": [
      "guild-wars/cantha-*.*"
    ],
    "videos": [],
    "cycle_interval": 300
  }
}

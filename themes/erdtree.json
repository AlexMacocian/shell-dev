{
  "name": "Erdtree",
  "colors": {
    "bg0": "#0B0B0F",
    "bg1": "#1A1610",
    "bg2": "#2B2420",
    "bg3": "#3D3530",
    "border": "#E0B848",
    "accent1": "#F0C040",
    "accent2": "#D87838",
    "text": "#F0DDB8",
    "text_dim": "#C8A878",
    "red": "#E04848",
    "green": "#9CB060",
    "blue": "#6090C0",
    "inactive": "#5A4F40",
    "saturation": 0.10
  },
  "hyprland": {
    "border_size": 2,
    "rounding": 4,
    "gaps_in": 4,
    "gaps_out": 16,
    "shadow_range": 8,
    "shadow_render_power": 3,
    "blur_size": 5,
    "blur_passes": 2,
    "blur_vibrancy": 0.2,
    "active_opacity": 1.0,
    "inactive_opacity": 0.93,
    "animation_speed_global": 12,
    "animation_speed_border": 6,
    "animation_speed_windows": 5.5,
    "animation_speed_windows_in": 5,
    "animation_speed_windows_out": 2,
    "animation_speed_fade_in": 2.5,
    "animation_speed_fade_out": 2,
    "animation_speed_workspaces": 3
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": [
      "FontAwesome",
      "Roboto",
      "sans-serif"
    ],
    "size": 12
  },
  "gtk": {
    "color_scheme": "prefer-dark",
    "theme": "Adwaita-dark"
  },
  "waybar": {
    "height": 34,
    "separator": "◆",
    "opacity": 0.82,
    "border_width": 2,
    "workspace_labels": [
      "I",
      "II",
      "III",
      "IV",
      "V",
      "VI",
      "VII",
      "VIII",
      "IX",
      "X"
    ]
  },
  "wallpapers": {
    "fit_mode": "cover",
    "images": [
      "elden-ring/sote-*.*",
      "elden-ring/gateofdivinity-*.*",
      "elden-ring/leyndell-*.*"
    ],
    "videos": [],
    "cycle_interval": 300
  }
}
